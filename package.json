{
  "name": "fourtiles",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "dev": "vite",
    "format": "prettier --write .",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.{css,vue}\"",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:knip": "knip",
    "lint": "yarn lint:eslint && yarn lint:stylelint && yarn lint:oxlint && yarn lint:knip",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --ui",
    "test:unit": "vitest",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@sentry/vue": "^10.45.0",
    "@tabler/icons-vue": "^3.40.0",
