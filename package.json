{
  "name": "fourtiles",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "dev": "vite",
    "format": "prettier --write .",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.{css,vue}\"",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:knip": "knip",
    "lint": "yarn lint:eslint && yarn lint:stylelint && yarn lint:oxlint && yarn lint:knip",
    "preview": "vite preview",
    "test:e2e": "start-server-and-test 'vite preview --port 4173 --host 127.0.0.1' http://127.0.0.1:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173 --host 127.0.0.1' http://127.0.0.1:4173 'cypress open --e2e'",
    "test:unit": "vitest",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@sentry/vue": "^10.44.0",
    "@tabler/icons-vue": "^3.40.0",
    "canvas-confetti": "^1.9.4",
    "lodash-es": "^4.17.23",
    "mitt": "^3.0.1",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/vue": "^8.1.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jsdom": "^28.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/setimmediate": "^1.0.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-dom": "^3.5.30",
    "@vue/server-renderer": "^3.5.30",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^15.12.0",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "knip": "^5.88.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.56.0",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "setimmediate": "^1.0.5",
    "start-server-and-test": "^2.1.5",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "yarn@4.13.0"
}
